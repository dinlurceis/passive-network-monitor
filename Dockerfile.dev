FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

# Install core build tools required by CLion
RUN apt-get update && apt-get install -y --no-install-recommends \
    cmake ninja-build make gcc g++ gdb pkg-config git ca-certificates \
    libpcap-dev \
    libpq-dev \
    libspdlog-dev \
    nlohmann-json3-dev \
    libgtest-dev \
    && rm -rf /var/lib/apt/lists/*

# Build libpqxx 7.9.2 from source (C++20 ABI fix for Ubuntu 24.04)
RUN git clone --depth 1 --branch 7.9.2 https://github.com/jtv/libpqxx.git /tmp/libpqxx \
    && cmake -S /tmp/libpqxx -B /tmp/libpqxx/build -G Ninja \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_CXX_STANDARD=20 \
        -DSKIP_BUILD_TEST=ON \
        -DBUILD_SHARED_LIBS=ON \
    && cmake --build /tmp/libpqxx/build \
    && cmake --install /tmp/libpqxx/build \
    && ldconfig \
    && rm -rf /tmp/libpqxx
